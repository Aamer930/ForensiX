# AI Backend — "claude" (default) or "ollama"
AI_MODE=claude

# Required when AI_MODE=claude
ANTHROPIC_API_KEY=sk-ant-...

# Ollama settings — only needed when AI_MODE=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Optional — enables VirusTotal enrichment for suspicious IOCs
VT_API_KEY=
