# ── AI Backend ────────────────────────────────────────────────
# Choose: "claude" (default) or "ollama"
AI_MODE=claude

# ── Claude API (required if AI_MODE=claude) ───────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Ollama (required if AI_MODE=ollama) ───────────────────────
# Make sure Ollama is running on your host before starting Docker
# Run: ollama pull llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
